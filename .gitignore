*.swo
*.DS_Store

# Nix
result
result-*
.direnv/

# IDEs
.vscode/
.idea/
*.iml
*.sublime-workspace

# Gradle
# Stray plugin-marker extraction junk left by Gradle runs at the repo root.
/META-INF/
tapi-shim/.gradle/
# Use ** (not trailing /) so the negation below can un-ignore the pre-built JAR.
# Git cannot negate a file inside an ignored directory, but can inside an ignored glob.
tapi-shim/build/**
# Pre-built JAR must be git-tracked so Nix flake can reference it as a path input.
# Phase 3 will replace this with a Kotlin-in-Nix build; until then the JAR is vendored.
!tapi-shim/build/libs/
!tapi-shim/build/libs/tapi-shim.jar
**/fixtures/**/.gradle

# Flutter/Dart/Gradle fixture build state
**/fixtures/**/.dart_tool
tests/fixtures/flutter/*/build/
tests/fixtures/flutter/*/android/build/
tests/fixtures/flutter/*/android/app/build/
tests/fixtures/gradle/*/build/
tests/fixtures/gradle/*/app/build/

# OMC
.omc/notepad.md
.omc/specs
