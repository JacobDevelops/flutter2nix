# Rust
/target/
**/*.rs.bk
*.pdb
*.swp
*.swo
*~
.DS_Store

# Nix
result
result-*
.direnv/
.devenv/

# IDEs
.vscode/
.idea/
.zed/
*.iml
*.sublime-workspace

# Gradle
# Stray plugin-marker extraction junk left by Gradle runs at the repo root.
/META-INF/
tapi-shim/.gradle/
# Use ** (not trailing /) so the negation below can un-ignore the pre-built JAR.
# Git cannot negate a file inside an ignored directory, but can inside an ignored glob.
tapi-shim/build/**
# The pre-built JAR is vendored so Nix can reference it as a fixed-output path input.
!tapi-shim/build/libs/
!tapi-shim/build/libs/tapi-shim.jar
**/fixtures/**/.gradle

# CocoaPods state in iOS fixtures — pod install regenerates it from the
# committed Podfile.lock; only Podfile/Podfile.lock/workspace are tracked.
**/fixtures/**/Pods/

# Flutter/Dart/Gradle fixture build state
**/fixtures/**/.dart_tool
tests/fixtures/flutter/*/build/
tests/fixtures/flutter/*/android/build/
tests/fixtures/flutter/*/android/app/build/
tests/fixtures/gradle/*/build/
tests/fixtures/gradle/*/app/build/

# Local iOS signing material for the fnx signing e2e (paths + IDs; the .p12
# password is referenced via IOS2NIX_P12_PASSWORD_FILE). Machine-specific,
# never committed.
.ios2nix-signing.env

# OMC
.omc/notepad.md
.omc/specs
